    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0"
  },
  "devDependencies": {
    "prisma": "^5.13.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}