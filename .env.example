# ─── BANCO DE DADOS ────────────────────────────────────────────────
DATABASE_URL="postgresql://licitabr:senha@localhost:5432/licitabr"

# ─── REDIS ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── ELASTICSEARCH ─────────────────────────────────────────────────
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_INDEX_LICITACOES="licitacoes"

# ─── JWT / AUTH ────────────────────────────────────────────────────
JWT_SECRET="troque-por-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="outro-segredo-longo-e-aleatorio"

# ─── API BACKEND ───────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ─── NEXT.JS FRONTEND ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
NEXT_PUBLIC_SITE_URL="https://licitabr.com.br"
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@sentry.io/xxxx"

# ─── STORAGE (S3 / Cloudflare R2) ──────────────────────────────────
S3_BUCKET="licitabr-editais"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="sua-access-key"
S3_SECRET_ACCESS_KEY="sua-secret-key"
S3_ENDPOINT="https://sua-conta.r2.cloudflarestorage.com"  # R2 ou S3

# ─── E-MAIL (SendGrid) ─────────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxx"
EMAIL_FROM="alertas@licitabr.com.br"
EMAIL_FROM_NAME="LicitaBR"

# ─── TELEGRAM BOT ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="seu-token-do-botfather"

# ─── PAGAMENTOS (Stripe) ───────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxx"
NEXT_PUBLIC_STRIPE_PRICE_BASICO="price_xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PRICE_PROFISSIONAL="price_yyyyyyyyyyyyyyyy"

# ─── PNCP API ──────────────────────────────────────────────────────
PNCP_API_BASE_URL="https://pncp.gov.br/api/pncp/v1"

# ─── SCRAPER ───────────────────────────────────────────────────────
SCRAPER_CONCURRENCY=3
SCRAPER_USER_AGENT="Mozilla/5.0 (compatible; LicitaBR-Bot/1.0)"
SCRAPER_HEADLESS=true

# ─── COMUNICAÇÃO INTERNA (scraper → api) ──────────────────
INTERNAL_API_URL="http://localhost:3001"
INTERNAL_API_KEY="chave-secreta-interna-longa"

# ─── MONITORAMENTO ─────────────────────────────────────────────────
SENTRY_DSN="https://xxxx@sentry.io/xxxx"
